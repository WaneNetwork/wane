{
  "name": "wane-sdk",
  "version": "0.3.1",
  "description": "Wane SDK: on-chain immune memory for AI agents. One 7702 signature, then every send is screened against the antibody registry before it runs.",
  "license": "MIT",
  "homepage": "https://github.com/WaneProtocol/wane-base#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WaneProtocol/wane-base.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/WaneProtocol/wane-base/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "wane",
    "ai-agent",
    "security",
    "antibody",
    "threat-intelligence",
    "base",
    "onchain",
    "wallet-drainer"
  ],
  "peerDependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "typescript": "^5",
    "viem": "^2.21.55"
  }
}
